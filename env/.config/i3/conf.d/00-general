### WORKSPACE ENUMERATION ###
set $WS1 "1"
set $WS2 "2"
set $WS3 "3"
set $WS4 "4"
set $WS5 "5"
set $WS6 "6"

### WORKSPACE SCREENS ###
workspace $WS1 output Virtual1
workspace $WS2 output Virtual1
workspace $WS3 output Virtual1

workspace $WS4 output Virtual1
workspace $WS5 output Virtual1
workspace $WS6 output Virtual1

# Disable titlebars but allow borders
font pango:Source Code Pro 8
for_window [class="^.*"] border pixel 1

### GAPS ###
gaps inner all set 5
gaps outer all set 2

